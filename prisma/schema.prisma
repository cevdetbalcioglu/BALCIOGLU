// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  files        File[]
  assets       Asset[]
  transactions Transaction[]
  assetNotes   AssetNote[]
  balance      Balance?
  vaultItems  VaultItem[]
  role           UserRole  @default(USER)
  menuExceptions UserMenuException[]
  pigeons     Pigeon[]
  pigeonTeams PigeonTeam[]
  clutches    Clutch[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model File {
  id         String   @id @default(cuid())
  name       String
  storedName String
  size       Int
  mimeType   String
  path       String
  userId     String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AssetCategory {
  FOREX
  GOLD
  STOCK
  FUND
  CRYPTO
  OTHER
}

enum TransactionType {
  BUY
  SELL
}

enum BalanceMovementType {
  DEPOSIT
  WITHDRAW
  BUY_DEBIT
  SELL_CREDIT
}

model Asset {
  id        String        @id @default(cuid())
  userId    String
  category  AssetCategory
  symbol    String
  name      String
  quantity  Float         @default(0)
  avgCost   Float         @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  notes        AssetNote[]

  @@unique([userId, symbol])
}

model Transaction {
  id           String          @id @default(cuid())
  userId       String
  assetId      String
  type         TransactionType
  quantity     Float
  pricePerUnit Float
  totalAmount  Float
  spotPrice    Float?
  note         String?
  transactedAt DateTime        @default(now())
  createdAt    DateTime        @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model AssetNote {
  id        String   @id @default(cuid())
  userId    String
  assetId   String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

model Balance {
  id        String   @id @default(cuid())
  userId    String   @unique
  amount    Float    @default(0)
  updatedAt DateTime @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  movements BalanceMovement[]
}

model BalanceMovement {
  id          String              @id @default(cuid())
  balanceId   String
  type        BalanceMovementType
  amount      Float
  description String?
  createdAt   DateTime            @default(now())

  balance Balance @relation(fields: [balanceId], references: [id], onDelete: Cascade)
}


// prisma/schema.prisma — dosyanın sonuna ekle

model VaultItem {
  id         String    @id @default(cuid())
  userId     String
  title      String
  category   String    @default("login") // login | card | note | other
  username   String?
  password   String    // AES-256-GCM şifreli (hex)
  url        String?
  notes      String?
  iv         String    // Her kayıt için benzersiz IV (hex)
  isFavorite Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}



// prisma/schema.prisma — mevcut dosyaya eklenecek

// User modeline ekle:
// role        UserRole  @default(USER)
// menuExceptions UserMenuException[]

enum UserRole {
  ADMIN
  USER
}

model MenuItem {
  id          String   @id @default(cuid())
  label       String                        // Görünen ad: "Dashboard", "Yatırımlarım"
  href        String                        // "/dashboard/portfolio"
  icon        String?                       // Emoji veya icon adı
  parentId    String?                       // Üst menü (null = ana menü)
  order       Int      @default(0)          // Sıralama
  isActive    Boolean  @default(true)       // Sistemden tamamen kaldırmadan devre dışı bırak
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      MenuItem?  @relation("MenuTree", fields: [parentId], references: [id])
  children    MenuItem[] @relation("MenuTree")

  rolePermissions RoleMenuPermission[]
  userExceptions  UserMenuException[]
}

model RoleMenuPermission {
  id         String   @id @default(cuid())
  role       UserRole
  menuItemId String
  createdAt  DateTime @default(now())

  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([role, menuItemId])
}

model UserMenuException {
  id         String   @id @default(cuid())
  userId     String
  menuItemId String
  type       String   // "GRANT" | "REVOKE" — role iznini bireysel geç
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([userId, menuItemId])
}



// prisma/schema.prisma — dosyanın sonuna ekle

model Pigeon {
  id          String   @id @default(cuid())
  userId      String
  ringId      String                        // TR-24-T0-01
  ringLabel   String                        // Bilezik Renk / No: "Siyah 081"
  gender      String?                       // "Erkek" | "Dişi"
  performance String?
  health      String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Pedigri ilişkileri
  fatherOf  Clutch[] @relation("ClutchFather")
  motherOf  Clutch[] @relation("ClutchMother")
  hatchedIn ClutchEgg[]                     // Bu kuş hangi yumurtadan çıktı

  @@unique([userId, ringId])
}

model PigeonTeam {
  id          String   @id @default(cuid())
  userId      String
  teamNo      Int                           // 1, 2, 3...
  season      String?                       // "2025-2026"
  motherLabel String?                       // Anne bilezik etiketi
  fatherLabel String?                       // Baba bilezik etiketi
  ringColor   String?                       // "Mor - Mor"
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clutches Clutch[]

  @@unique([userId, teamNo])
}

model Clutch {
  id          String   @id @default(cuid())
  userId      String
  teamId      String
  round       Int                           // Tur: 1, 2, 3...
  eggDate     DateTime?                     // Yumurta tarihi
  hatchDate   DateTime?                     // Çıkış tarihi
  fatherId    String?                       // Baba kuş
  motherId    String?                       // Anne kuş
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   PigeonTeam  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  father Pigeon?     @relation("ClutchFather", fields: [fatherId], references: [id])
  mother Pigeon?     @relation("ClutchMother", fields: [motherId], references: [id])
  eggs   ClutchEgg[]
}

model ClutchEgg {
  id        String   @id @default(cuid())
  clutchId  String
  pigeonId  String?                         // Bu yumurtadan çıkan kuş
  createdAt DateTime @default(now())

  clutch  Clutch   @relation(fields: [clutchId], references: [id], onDelete: Cascade)
  pigeon  Pigeon?  @relation(fields: [pigeonId], references: [id])
}

